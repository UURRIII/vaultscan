# Copy to .env (it's gitignored). All values are optional with sensible defaults.

# Secret used to sign JWT auth tokens — set a long random string in production.
VAULTSCAN_SECRET=change-me-to-a-long-random-string

# Default admin account created on first run.
VAULTSCAN_ADMIN_EMAIL=admin@vaultscan.local
VAULTSCAN_ADMIN_PASSWORD=changeme123

# AI Analyst — local Ollama (free, private). Default points at localhost.
OLLAMA_URL=http://localhost:11434
VAULTSCAN_AI_MODEL=llama3.1:8b

# SQLite location (Docker sets this to a mounted volume).
# VAULTSCAN_DB=/data/vaultscan.db
